# Configuration Uber API
ENVIRONMENT=development
DEBUG=true
APP_NAME=Uber API
APP_VERSION=2.0.0

# Serveur
HOST=0.0.0.0
PORT=8000

# Sécurité (CHANGEZ CES VALEURS EN PRODUCTION)
SECRET_KEY=your-super-secret-key-change-this-in-production-minimum-32-chars
JWT_SECRET_KEY=your-jwt-secret-key-change-this-too-minimum-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Mots de passe
PASSWORD_MIN_LENGTH=8
BCRYPT_ROUNDS=12

# Sessions
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Base de données
DATABASE_URL=sqlite:///./uber_api.db
DATABASE_ECHO=false

# Redis (optionnel)
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20

# CORS
CORS_ALLOWED_ORIGINS=["*"]
CORS_ALLOWED_METHODS=["GET","POST","PUT","DELETE"]
CORS_ALLOWED_HEADERS=["*"]
CORS_ALLOW_CREDENTIALS=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text

# Monitoring
ENABLE_METRICS=true

