# Configuration de production pour l'application VTC sécurisée
# Copiez ce fichier vers .env et configurez vos valeurs

# === ENVIRONNEMENT ===
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# === SÉCURITÉ JWT ===
JWT_SECRET_KEY=your_super_secret_jwt_key_here_minimum_32_chars
JWT_REFRESH_SECRET_KEY=your_super_secret_refresh_key_here_minimum_32_chars
RESET_PASSWORD_TOKEN=your_reset_password_token_here

# === BASE DE DONNÉES ===
DATABASE_URL=postgresql://user:password@localhost/vtc_production
DATABASE_PASSWORD=your_secure_database_password

# === CHIFFREMENT ===
ENCRYPTION_PASSWORD=your_encryption_master_password_here
ENCRYPTION_SALT=your_encryption_salt_here

# === PAIEMENTS STRIPE ===
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# === SERVICES EXTERNES ===
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token

# === EMAIL ===
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password

# === SÉCURITÉ RÉSEAU ===
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
RATE_LIMIT_PER_MINUTE=60

# === SERVEUR ===
HOST=0.0.0.0
PORT=8000
WORKERS=4

