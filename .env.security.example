# Variables d'environnement de sécurité pour l'application VTC
# IMPORTANT: Ne jamais commiter ces valeurs en production !

# Clé maître de chiffrement (générer avec: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_MASTER_KEY=your_base64_encoded_master_key_here

# Clé AES-256 pour chiffrement AEAD (générer avec: python -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())")
AES_ENCRYPTION_KEY=your_base64_encoded_aes_key_here

# Clés Stripe (remplacer les valeurs par défaut)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Autres variables de sécurité
JWT_SECRET_KEY=your_jwt_secret_key_here
DATABASE_ENCRYPTION_KEY=your_database_encryption_key

# Configuration de sécurité
SECURITY_LEVEL=high
ENABLE_AUDIT_LOGGING=true
ENABLE_DATA_ENCRYPTION=true

# Instructions de génération des clés:
# 1. Clé Fernet: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 2. Clé AES-256: python -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
# 3. JWT Secret: python -c "import secrets; print(secrets.token_urlsafe(32))"

